{
	"name": "sv11-ui",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite dev",
		"changelog": "git-cliff --config cliff.toml --output content/changelog.md",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "velite && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix",
		"build:registry": "pnpm shadcn-svelte registry build"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.0",
		"@eslint/js": "^9.29.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.7.0",
		"@prettier/sync": "^0.6.1",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tabler/icons-svelte": "^3.41.1",
		"@tailwindcss/vite": "^4.2.1",
		"@threlte/core": "^8.5.9",
		"@threlte/extras": "^9.14.6",
		"@types/node": "^25.6.0",
		"@types/three": "^0.183.1",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.9.2",
		"git-cliff": "^2.12.0",
		"globals": "^17.5.0",
		"magic-string": "^0.30.21",
		"mdsx": "^0.0.7",
		"mode-watcher": "^1.1.0",
		"motion": "^12.38.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"rehype-pretty-code": "^0.14.3",
		"rehype-slug": "^6.0.0",
		"remark-code-import": "^1.2.0",
		"remark-gfm": "^4.0.1",
		"shadcn-svelte": "^1.2.7",
		"shiki": "^4.0.2",
		"stick-to-bottom-svelte": "^1.0.3",
		"svelte": "^5.55.2",
		"svelte-check": "^4.0.0",
		"svelte-streamdown": "^3.0.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.2.1",
		"three": "^0.183.2",
		"ts-morph": "^28.0.0",
		"tw-animate-css": "^1.3.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.34.0",
		"unist-builder": "^4.0.0",
		"unist-util-visit": "^5.1.0",
		"velite": "^0.3.1",
		"vite": "^8.0.8",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
